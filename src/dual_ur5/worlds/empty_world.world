<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="default">
    <include>
      <uri>model://sun</uri>
    </include>
    
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://table</uri>
      <name>work_table</name>
      <pose>0 0.5 0 0 0 1.5708</pose>
    </include>

    <plugin name="gazebo_link_attacher" filename="libgazebo_link_attacher.so"/>
    
  </world>
</sdf>