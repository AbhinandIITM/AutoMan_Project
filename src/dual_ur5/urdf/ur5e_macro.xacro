<?xml version="1.0" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="ur5e_arm" params="prefix parent *origin">

    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/base.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/base.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="4.0"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.00443333156" ixy="0.0" ixz="0.0" iyy="0.00443333156" iyz="0.0" izz="0.0072"/>
      </inertial>
    </link>

    <link name="${prefix}shoulder_link">
      <visual>
        <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/shoulder.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/shoulder.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="3.7"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.010267495893" ixy="0.0" ixz="0.0" iyy="0.010267495893" iyz="0.0" izz="0.00666"/>
      </inertial>
    </link>

    <link name="${prefix}upper_arm_link">
      <visual>
        <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.138"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/upperarm.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.138"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/upperarm.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="8.393"/>
        <origin rpy="0 1.5707963267948966 0" xyz="-0.2125 0.0 0.138"/>
        <inertia ixx="0.1338857818623325" ixy="0.0" ixz="0.0" iyy="0.1338857818623325" iyz="0.0" izz="0.0151074"/>
      </inertial>
    </link>

    <link name="${prefix}forearm_link">
      <visual>
        <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.007"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/forearm.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.007"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/forearm.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.275"/>
        <origin rpy="0 1.5707963267948966 0" xyz="-0.1961 0.0 0.007"/>
        <inertia ixx="0.031209355099586295" ixy="0.0" ixz="0.0" iyy="0.031209355099586295" iyz="0.0" izz="0.004095"/>
      </inertial>
    </link>

    <link name="${prefix}wrist_1_link">
      <visual>
        <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.127"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/wrist1.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.127"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/wrist1.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.219"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.0025598989760400002" ixy="0.0" ixz="0.0" iyy="0.0025598989760400002" iyz="0.0" izz="0.0021942"/>
      </inertial>
    </link>

    <link name="${prefix}wrist_2_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 -0.0997"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/wrist2.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 -0.0997"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/wrist2.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.219"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.0025598989760400002" ixy="0.0" ixz="0.0" iyy="0.0025598989760400002" iyz="0.0" izz="0.0021942"/>
      </inertial>
    </link>

    <link name="${prefix}wrist_3_link">
      <visual>
        <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.0989"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/visual/wrist3.dae"/>
        </geometry>
        <material name="LightGrey">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.0989"/>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/wrist3.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1879"/>
        <origin rpy="0 0 0" xyz="0.0 0.0 -0.0229"/>
        <inertia ixx="9.890410052167731e-05" ixy="0.0" ixz="0.0" iyy="9.890410052167731e-05" iyz="0.0" izz="0.0001321171875"/>
      </inertial>
    </link>

    <joint name="${prefix}shoulder_pan_joint" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}shoulder_link"/>
      <origin rpy="0 0 0" xyz="0 0 0.1625"/>
      <axis xyz="0 0 1"/>
      <limit effort="150.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <joint name="${prefix}shoulder_lift_joint" type="revolute">
      <parent link="${prefix}shoulder_link"/>
      <child link="${prefix}upper_arm_link"/>
      <origin rpy="1.570796327 0 0" xyz="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="150.0" lower="3.141592653589793" upper="6.283185307179586" velocity="3.141592653589793"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <joint name="${prefix}elbow_joint" type="revolute">
      <parent link="${prefix}upper_arm_link"/>
      <child link="${prefix}forearm_link"/>
      <origin rpy="0 0 0" xyz="-0.425 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="150.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.141592653589793"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <joint name="${prefix}wrist_1_joint" type="revolute">
      <parent link="${prefix}forearm_link"/>
      <child link="${prefix}wrist_1_link"/>
      <origin rpy="0 0 0" xyz="-0.3922 0 0.1333"/>
      <axis xyz="0 0 1"/>
      <limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <joint name="${prefix}wrist_2_joint" type="revolute">
      <parent link="${prefix}wrist_1_link"/>
      <child link="${prefix}wrist_2_link"/>
      <origin rpy="1.570796327 0 0" xyz="0 -0.0997 -2.044881182297852e-11"/>
      <axis xyz="0 0 1"/>
      <limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <joint name="${prefix}wrist_3_joint" type="revolute">
      <parent link="${prefix}wrist_2_link"/>
      <child link="${prefix}wrist_3_link"/>
      <origin rpy="1.570796326589793 3.141592653589793 3.141592653589793" xyz="0 0.0996 -2.042830148012698e-11"/>
      <axis xyz="0 0 1"/>
      <limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <link name="${prefix}base"/>
    <joint name="${prefix}base_link-base_fixed_joint" type="fixed">
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}base"/>
    </joint>

    <link name="${prefix}flange"/>
    <joint name="${prefix}wrist_3-flange" type="fixed">
      <parent link="${prefix}wrist_3_link"/>
      <child link="${prefix}flange"/>
      <origin rpy="0 -1.5707963267948966 -1.5707963267948966" xyz="0 0 0"/>
    </joint>

    <link name="${prefix}tool0"/>
    <joint name="${prefix}flange-tool0" type="fixed">
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <parent link="${prefix}flange"/>
      <child link="${prefix}tool0"/>
    </joint>

    <joint name="${prefix}screw_tool_end_effector_flange" type="fixed">
      <parent link="${prefix}tool0"/>
      <child link="${prefix}screw_tool_base_link"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}screw_tool_base_link">
      <visual>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/end_effector.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="3.141592653589793 0 1.5707963267948966"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.03" length="0.12"/>
        </geometry>
        <origin xyz="0 0 0.06" rpy="3.141592653589793 0 1.5707963267948966"/>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.268"/>
        <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0001"/>
      </inertial>
    </link>

    <link name="${prefix}screw_tool_camera_link"> </link>
    <joint name="${prefix}screw_tool_camera_joint" type="fixed">
        <parent link="${prefix}screw_tool_base_link"/>
        <child link="${prefix}screw_tool_camera_link"/>
        <origin xyz="-0.02 0 0.07989" rpy="3.141592653589793 3.141592653589793 0"/>
    </joint>

    <link name="${prefix}screw_tool_tool_point"> </link>
    <joint name="${prefix}screw_tool_tool_point_joint" type="fixed">
        <parent link="${prefix}screw_tool_base_link"/>
        <child link="${prefix}screw_tool_tool_point"/>
        <origin xyz="-0.0975 0 0.02" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}tool0_to_housing" type="fixed">
      <parent link="${prefix}tool0"/>
      <child link="${prefix}housing_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}housing_base_link">
      <visual>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/EndEffectorMountConnectorHousing-v1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.04" length="0.05"/>
        </geometry>
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${prefix}tool0_to_screwblock" type="fixed">
      <parent link="${prefix}tool0"/>
      <child link="${prefix}screwblock_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}screwblock_base_link">
      <visual>
        <geometry>
          <mesh filename="package://dual_ur5/urdf/meshes/collision/EndEffectorMountHousing_ScrewBlock-v1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="3.141592653589793 0 0"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.04" length="0.05"/>
        </geometry>
        <origin xyz="0 0 0" rpy="3.141592653589793 0 0"/>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0001"/>
      </inertial>
    </link>

    <ros2_control name="${prefix}system" type="system">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>
      <joint name="${prefix}shoulder_pan_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}shoulder_lift_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}elbow_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}wrist_1_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}wrist_2_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}wrist_3_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

  </xacro:macro>
</robot>